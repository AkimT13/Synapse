# Synapse currently supports `openai` and `ollama` for providers.
# For both LLM and embeddings, select your provider and model.
# The selected model must be exposed by the provider. 
# For openai, check the OpenAI API Documentation.
# For ollama, run `ollama list` in your terminal.

LLM_PROVIDER=
LLM_MODEL=

EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=

# Required if either provider above is `openai`, or if either is unset.
OPENAI_API_KEY=

# Override if Ollama runs elsewhere.
OLLAMA_BASE_URL=http://localhost:11434
